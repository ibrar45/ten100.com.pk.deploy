# Copy to .env and fill in real values (never commit .env)
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/railway
MONGO_MAX_POOL_SIZE=10

# Use a long random string; production requires 32+ chars (see src/config/env.js)
JWT_SECRET=change-me-use-openssl-rand-base64-48

JWT_EXPIRES_IN=7d

PORT=5000

# Comma-separated origins for browser clients (required in production if SPA is on another host)
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example

# Set to 1 behind Railway / reverse proxy (rate limit + IP)
TRUST_PROXY=0

RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30

LOG_LEVEL=info

# Optional: POST /api/role/seed header x-role-seed-key must match
# ROLE_SEED_KEY=
